// Prisma: схема БД и генератор клиента.
// Документация: https://www.prisma.io/docs

generator client {
  provider      = "prisma-client-js"
  // Vercel (Linux): корректный query engine в проде
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // URL берётся из .env — не храните реальные пароли в репозитории
  url      = env("DATABASE_URL")
}

// --- Заготовка этапа 1: минимальная модель под будущих пользователей ---
// На следующих этапах сюда добавят Car, CarImage, Booking и поля профиля.

/// Роль в системе: клиент сайта или полный доступ (админ-панель).
enum UserRole {
  CUSTOMER
  ADMIN
}

/// Пользователь: вход по email/паролю (хэш в passwordHash).
model User {
  id           String               @id @default(cuid())
  /// Уникальный email для входа и связи
  email        String               @unique
  /// Bcrypt-хэш пароля; null — вход по паролю недоступен (старые записи).
  passwordHash String?              @map("password_hash")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  role         UserRole             @default(CUSTOMER)
  /// Профиль клиента (редактирование в админ-панели и позже в личном кабинете).
  lastName     String?              @map("last_name")
  firstName    String?              @map("first_name")
  patronymic   String?
  phone        String?
  address      String?              @db.Text
  /// Паспортные данные (серия, номер, кем выдан); хранить и показывать только доверенным ролям.
  passportData String?              @map("passport_data") @db.Text
  /// Возраст полных лет (для договора аренды).
  ageYears     Int?                 @map("age_years")
  /// Серия паспорта (структурировано для PDF договора).
  passportSeries   String?          @map("passport_series")
  passportNumber   String?          @map("passport_number")
  passportIssuedBy String?          @map("passport_issued_by") @db.Text
  /// Дата обезличивания/удаления персональных данных (по запросу или по ретеншну).
  personalDataErasedAt DateTime?    @map("personal_data_erased_at")
  resetTokens  PasswordResetToken[]
  bookings     Booking[]
  consents     ConsentRecord[]
  personalDataErasures PersonalDataErasure[] @relation("erasure_user")
  performedPersonalDataErasures PersonalDataErasure[] @relation("erasure_performed_by")

  @@map("users")
}

/// Одноразовый токен сброса пароля (в БД хранится хэш токена из письма).
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("password_reset_tokens")
}

/// Автомобиль в автопарке (витрина: только active = true).
model Car {
  id              String     @id @default(cuid())
  /// Стабильный URL-сегмент, например toyota-camry
  slug            String     @unique
  make            String
  model           String
  description     String     @db.Text
  /// Цена за сутки в целых рублях (без копеек).
  pricePerDayRub  Int        @map("price_per_day_rub")
  /// Минимальный срок аренды в сутках (включительно).
  minRentalDays   Int        @default(1) @map("min_rental_days")
  /// Данные для договора аренды (PDF).
  modelYear                 Int?    @map("model_year")
  color                     String?
  plateNumber               String? @map("plate_number")
  registrationCertificate   String? @map("registration_certificate") @db.Text
  active          Boolean    @default(true)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  images          CarImage[]
  bookings        Booking[]

  @@map("cars")
}

/// Статус брони: оплата и отмена — на следующих этапах.
enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum BookingPaymentPlan {
  FULL
  FIRST_DAY
}

enum BookingPlaceMode {
  OFFICE
  ADDRESS
}

enum ConsentType {
  PDP
  MARKETING
}

/// Бронь: даты включительно (startDate … endDate), цена за весь период.
model Booking {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  carId         String        @map("car_id")
  startDate     DateTime      @map("start_date") @db.Date
  endDate       DateTime      @map("end_date") @db.Date
  status        BookingStatus @default(PENDING_PAYMENT)
  paymentPlan   BookingPaymentPlan @default(FULL) @map("payment_plan")
  paidAmountRub Int           @default(0) @map("paid_amount_rub")
  totalPriceRub Int           @map("total_price_rub")
  pickupMode    BookingPlaceMode @default(OFFICE) @map("pickup_mode")
  pickupAddress String?          @map("pickup_address") @db.Text
  pickupFeeRub  Int              @default(0) @map("pickup_fee_rub")
  pickupTimeSlot String?         @map("pickup_time_slot") @db.VarChar(20)
  dropoffMode   BookingPlaceMode @default(OFFICE) @map("dropoff_mode")
  dropoffAddress String?         @map("dropoff_address") @db.Text
  dropoffFeeRub Int              @default(0) @map("dropoff_fee_rub")
  dropoffTimeSlot String?        @map("dropoff_time_slot") @db.VarChar(20)
  secondDriverEnabled Boolean @default(false) @map("second_driver_enabled")
  secondDriverFirstName String? @map("second_driver_first_name")
  secondDriverLastName String? @map("second_driver_last_name")
  secondDriverAgeYears Int? @map("second_driver_age_years")
  secondDriverPassportData String? @map("second_driver_passport_data") @db.Text
  secondDriverFeeRub Int @default(0) @map("second_driver_fee_rub")
  childSeatEnabled Boolean @default(false) @map("child_seat_enabled")
  childSeatFeeRub Int @default(0) @map("child_seat_fee_rub")
  /// Снимок данных арендатора для генерации договора (PDF).
  contractMeta  Json?       @map("contract_meta")
  consents      ConsentRecord[]
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  car           Car           @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([carId])
  @@map("bookings")
}

model ConsentRecord {
  id         String      @id @default(cuid())
  type       ConsentType
  docVersion String      @map("doc_version") @db.VarChar(40)
  docPath    String      @map("doc_path") @db.VarChar(200)
  acceptedAt DateTime    @default(now()) @map("accepted_at")
  ip         String?     @db.VarChar(80)
  userAgent  String?     @map("user_agent") @db.Text
  userId     String?     @map("user_id")
  bookingId  String?     @map("booking_id")
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  booking    Booking?    @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookingId])
  @@index([type, acceptedAt])
  @@map("consent_records")
}

model PersonalDataErasure {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  performedById String?  @map("performed_by_id")
  performedAt   DateTime @default(now()) @map("performed_at")
  reason        String   @db.VarChar(120)
  note          String?  @db.Text

  user          User     @relation("erasure_user", fields: [userId], references: [id], onDelete: Cascade)
  performedBy   User?    @relation("erasure_performed_by", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([performedAt])
  @@map("personal_data_erasures")
}

/// Фото автомобиля: пока внешний URL (этап 5 — загрузка в S3).
model CarImage {
  id        String   @id @default(cuid())
  carId     String   @map("car_id")
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  alt       String?
  createdAt DateTime @default(now()) @map("created_at")
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
  @@map("car_images")
}

/// Дополнительные услуги (Приложение №3 к договору): цена за сутки и/или текст фиксированной цены.
model ExtraService {
  id                 String   @id @default(cuid())
  name               String
  pricePerDayRub     Int      @default(0) @map("price_per_day_rub")
  nonDailyPriceText  String?  @map("non_daily_price_text") @db.VarChar(200)
  sortOrder          Int      @default(0) @map("sort_order")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("extra_services")
}
