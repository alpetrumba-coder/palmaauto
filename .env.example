# Скопируйте в файл `.env` в этой же папке и подставьте свои значения.
#
# Строка подключения PostgreSQL для Prisma.
# Формат: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БД?schema=public
# Облачные БД (Neon, Supabase и т.д.) часто требуют: ?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/palmaauto?schema=public"
