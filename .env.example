# Скопируйте в файл `.env` в этой же папке и подставьте свои значения.
#
# Строка подключения PostgreSQL для Prisma.
# Формат: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БД?schema=public
# Облачные БД (Neon, Supabase и т.д.) часто требуют: ?sslmode=require
# Neon иногда добавляет channel_binding=require — в приложении параметр убирается (совместимость с Node pg).
DATABASE_URL="postgresql://user:password@localhost:5432/palmaauto?schema=public"
# Опционально (Neon): строка «Direct» без pooler — для надёжного prisma migrate deploy на CI/Vercel.
# DIRECT_URL="postgresql://..."

# Auth.js (NextAuth v5): сгенерируйте секрет, например: openssl rand -base64 32
AUTH_SECRET="замените_на_случайную_строку"
# Продакшен: базовый URL сайта (для ссылок в письмах Resend)
# AUTH_URL="https://palmaauto.vercel.app"

# Resend: API-ключ и отправитель (домен должен быть верифицирован в Resend; для теста — onboarding@resend.dev)
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"

# Уведомления администратору о новых бронях (на этот email придёт письмо с деталями и ссылкой в админку)
ADMIN_NOTIFY_EMAIL="admin@example.com"

# Первый администратор: создаётся при npm run db:seed; тем же email/паролем вход в /admin-panel (кнопка в подвале)
# INITIAL_ADMIN_EMAIL="admin@example.com"
# INITIAL_ADMIN_PASSWORD="минимум_8_символов"
